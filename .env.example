# --- 前端（Vite 暴露给浏览器，可选）---
# YouTube Data API v3：有 Key 时直连 Google，无 Key 时走本站 /api/invidious 代理
VITE_YOUTUBE_API_KEY=

# --- 仅 Vercel Serverless / 本地 dev（勿加 VITE_ 前缀）---
# Invidious 上游（无 YouTube Data API Key 时，搜索/频道/视频元数据走本站 /api/invidious 代理）。
# 勿填 MeTube 域名。公开实例列表与状态见：https://docs.invidious.io/instances/
# 复制本文件为 .env 后至少填一个可用实例；留空则返回 503（不再内置已关停的默认域名）。
# 切勿使用 invidious.projectsegfau.lt / 多数 *.projectsegfau.lt — 已关停，会返回纯文本 shutdown（搜索必失败）。
# 若遇 403 / shutdown / 超时，可主站 + 备用（逗号分隔，依次最多 4 个）：
# INVIDIOUS_UPSTREAM_URL=https://实例A
# INVIDIOUS_UPSTREAM_FALLBACKS=https://实例B,https://实例C
# 或一条里写满：INVIDIOUS_UPSTREAM_URLS=https://a,https://b
INVIDIOUS_UPSTREAM_URL=
INVIDIOUS_UPSTREAM_FALLBACKS=
# 可选：单次上游请求超时（毫秒）。本地 dev 未设置时默认 8000；Vercel 未设置时默认 2200
# INVIDIOUS_FETCH_TIMEOUT_MS=10000

# Railway 上的 MeTube 根地址（服务端转发 /api/metube/*，勿暴露密钥到浏览器）。
# 部署区别：MeTube 容器在 Railway；本仓库前端 + /api/* 多在 Vercel——二者通过 METUBE_URL 串联，与「MeTube 是否装在 Vercel」无关。
METUBE_URL=https://your-metube.up.railway.app
# 验证 MeTube 是否提供 Cookie 接口（在终端执行，替换为你的公网根 URL）：
#   curl -sS -o /dev/null -w "%{http_code}\n" "https://你的-metube.up.railway.app/cookie-status"
# 200 且返回 JSON 即支持；404 则镜像过旧，请用 alexta69/metube:latest 或 >= 2026.03.06，或改用 Volume 挂 cookies.txt + YTDL_OPTIONS 见 MeTube Wiki。

# 可选：合并进转发到 MeTube /add 的 ytdl_options_overrides（需 MeTube ALLOW_YTDL_OPTIONS_OVERRIDES=true）
# 例：{"extractor_args":{"youtube":{"player_client":["android"]}}}
METUBE_YTDL_OVERRIDES_JSON=

# 可选：MeTube 公网根地址（与 METUBE_URL 通常相同）。配置后「下载记录」可显示「下载文件」直链（/download/...）
VITE_METUBE_PUBLIC_URL=
